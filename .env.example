# Origem dos dados:
#   VITE_DATA_SOURCE=local  → store em localStorage (chave planejador:v2). Padrão.
#   VITE_DATA_SOURCE=api    → consome o backend HTTP (planejador-backend).
VITE_DATA_SOURCE=local

# URL da API local do backend, usada quando VITE_DATA_SOURCE=api.
# Sem header de auth: o backend é local, aberto e single-user.
VITE_API_URL=http://localhost:8000/api/v1
